{
  "name": "veloforge-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:api": "openapi-typescript-codegen --input ../contract.yaml --output src/api --client axios",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/ *.json",
    "format:check": "prettier --check src/ *.json"
  },
  "dependencies": {
    "@vueuse/core": "^13.7.0",
    "axios": "^1.6.2",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.3",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.20",
    "@types/node": "^24.2.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.33.0",
    "eslint-plugin-vue": "~10.4.0",
    "jiti": "^2.5.1",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "3.6.2",
    "typescript": "^5.3.3",
    "vite": "^7.1.1",
    "vue-tsc": "^3.0.5"
  }
}
