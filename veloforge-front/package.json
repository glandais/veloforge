{
  "name": "veloforge-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:api": "npx openapi-typescript-codegen --input ../contract.yaml --output src/api --client axios",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/ *.json",
    "format:check": "prettier --check src/ *.json"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.7.0",
    "openapi-typescript-codegen": "^0.31.0",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
